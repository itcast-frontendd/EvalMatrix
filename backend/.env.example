# ============================================================================
# EvalMatrix 环境变量配置模板
# 复制此文件为 .env 并填入你的实际配置
# ============================================================================

# ============================================================================
# Judge 模型配置（必填）
# 支持：网易 AI Gateway、OpenRouter、OpenAI 兼容 API
# ============================================================================

# 方案 1：网易 AI Gateway（推荐国内用户）
JUDGE_API_URL=https://aigw.netease.com/v1/chat/completions
JUDGE_API_KEY=your-netease-api-key-here
JUDGE_MODEL=gemini-2.5-flash

# 方案 2：OpenRouter（支持 Claude、GPT 等更多模型）
# JUDGE_API_URL=https://openrouter.ai/api/v1/chat/completions
# JUDGE_API_KEY=sk-or-v1-your-openrouter-key-here
# JUDGE_MODEL=anthropic/claude-3-5-sonnet-20241022

# 方案 3：OpenAI
# JUDGE_API_URL=https://api.openai.com/v1/chat/completions
# JUDGE_API_KEY=sk-your-openai-key-here
# JUDGE_MODEL=gpt-4o

# ============================================================================
# Judge 性能配置（可选，使用默认值可删除）
# ============================================================================
JUDGE_MAX_INPUT_TOKENS=200000
JUDGE_MAX_OUTPUT_TOKENS=64000
JUDGE_RPM_LIMIT=120
JUDGE_TPM_LIMIT=200000
JUDGE_CONCURRENCY=3
JUDGE_TIMEOUT=90

# ============================================================================
# 可选：Dify Workflow 配置
# ============================================================================
# DIFY_API_URL=https://your-dify-instance.com/v1/workflows/run
# DIFY_API_KEY=your-dify-api-key-here

# ============================================================================
# 可选：OpenRouter 备用配置（用于被测产品）
# ============================================================================
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
